# Environment Configuration Template
# 1. Copy to .env.local: cp .env.example .env.local
# 2. Fill in required secrets below
# 3. Override platform-specific paths if needed
#
# .env (committed) = shared defaults
# .env.local (gitignored) = your secrets & overrides

# Generate: openssl rand -base64 32
APP_SECRET=your_secret_key_here

# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_SERVER_SIDE_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
STRIPE_PRICE_ID=price_your_id_here
STRIPE_API_BASE=https://api.stripe.com

# This file is committed to git and contains safe defaults for development.
# Override any values in .env.local (gitignored) for your local environment.
NODE_ENV=development

JWT_EXPIRES_IN=15m

FRONTEND_URL=http://localhost:5173
FQDN=localhost

HTTPD_SCHEME=http
HTTPD_PORT=80
NODES_CONNECT_FQDN=localhost

PROFILE_STORAGE_PATH=/home/vagrant/.local/share/radicle/profiles/
RAD_BINARY_PATH=/home/vagrant/.radicle/bin/rad
APP_PODMAN_SOCKET=unix:///run/user/1000/podman/podman.sock
DATABASE_URL=postgres://garden:garden@localhost:5432/garden

RADICLE_NODE_CONTAINER=quay.io/radicle_garden/radicle-node:1.6.1
RADICLE_HTTPD_CONTAINER=quay.io/radicle_garden/radicle-httpd:0.23.0

DEFAULT_HTTPD_API_HOSTNAME=localhost
DEFAULT_HTTPD_API_PORT=9999
DEFAULT_HTTPD_API_SCHEME=http
PUBLIC_SERVICE_HOST_PORT=localhost:3080
NODE_MAX_STORAGE_BYTES=1073741824

# OPTIONAL
#RESEND_API_KEY=re_your_key_here
#EMAIL_SENDER_ADDRESS=noreply@yourdomain.com

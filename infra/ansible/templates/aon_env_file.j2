# Environment
NODE_ENV=production

# Required Secrets
APP_SECRET={{ app_secret }}
DATABASE_URL="{{ database_url }}"
STRIPE_SECRET_SERVER_SIDE_KEY={{ stripe_secret_key }}
STRIPE_WEBHOOK_SECRET={{ stripe_webhook_secret }}
STRIPE_PRICE_ID={{ stripe_price_id }}
STRIPE_API_BASE={{ stripe_api_base }}

# Optional Email Configuration
RESEND_API_KEY={{ resend_api_key }}
EMAIL_SENDER_ADDRESS={{ email_sender_address }}

# Platform-specific Paths
RAD_BINARY_PATH=/home/{{ system_username }}/.radicle/bin/rad
PROFILE_STORAGE_PATH={{ profile_storage_path }}
APP_PODMAN_SOCKET=unix:///run/user/{{ unix_user_id }}/podman/podman.sock

# JWT Configuration
JWT_EXPIRES_IN=15m

# Domain and Frontend Configuration
FQDN={{ garden_domain }}
FRONTEND_URL=https://{{ garden_domain }}
NODES_CONNECT_FQDN={{ garden_domain }}

# HTTP Daemon Configuration
HTTPD_SCHEME=https
HTTPD_PORT=443

# Radicle Container Images
RADICLE_NODE_CONTAINER={{ radicle_node_container }}
RADICLE_HTTPD_CONTAINER={{ radicle_httpd_container }}

# Public API Configuration
DEFAULT_HTTPD_API_HOSTNAME={{ garden_domain }}
DEFAULT_HTTPD_API_PORT=443
DEFAULT_HTTPD_API_SCHEME=https
PUBLIC_SERVICE_HOST_PORT={{ garden_domain }}
NODE_MAX_STORAGE_BYTES={{ node_max_storage_bytes }}

# Radicle Passphrase (empty for production)
RAD_PASSPHRASE=
